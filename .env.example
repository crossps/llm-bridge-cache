# LLM Bridge & Cache — environment template
# Copy to ".env" (or export these in your shell) and fill in your own keys.
# The bridge NEVER ships credentials — bring your own.

# --- Provider keys (referenced from config as "env:OPENAI_API_KEY", etc.) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Zhipu / Z.ai GLM key (get one at https://z.ai). OpenAI-compatible.
GLM_API_KEY=
# Moonshot AI "Kimi" key (get one at https://platform.moonshot.ai). OpenAI-compatible.
# Use api.moonshot.cn instead if your key was issued on the mainland-China platform.
MOONSHOT_API_KEY=

# You can supply multiple keys for one provider to enable round-robin rotation,
# e.g. OPENAI_API_KEY_1 / OPENAI_API_KEY_2 — then list them in the config's apiKeys array.
# OPENAI_API_KEY_1=
# OPENAI_API_KEY_2=

# --- Optional: protect the bridge itself ---
# If set, clients must send this as "Authorization: Bearer <key>".
LLM_BRIDGE_API_KEY=

# --- Optional server overrides (also settable in config / CLI flags) ---
# PORT=8787
# HOST=127.0.0.1
# LOG_LEVEL=info
