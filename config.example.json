{
  "port": 8787,
  "host": "127.0.0.1",
  "logLevel": "info",
  "apiKey": "env:LLM_BRIDGE_API_KEY",
  "defaultProvider": "anthropic",

  "providers": {
    "openai": {
      "baseUrl": "https://api.openai.com/v1",
      "apiKeys": ["env:OPENAI_API_KEY"],
      "models": ["gpt-4o", "gpt-4o-mini", "gpt-4.1", "o3", "o4-mini"]
    },
    "anthropic": {
      "baseUrl": "https://api.anthropic.com/v1",
      "apiKeys": ["env:ANTHROPIC_API_KEY"],
      "version": "2023-06-01",
      "models": ["claude-opus-4-5", "claude-sonnet-4-5", "claude-haiku-4-5"]
    },
    "glm": {
      "baseUrl": "https://api.z.ai/api/paas/v4",
      "apiKeys": ["env:GLM_API_KEY"],
      "models": ["glm-4.6", "glm-4.5", "glm-4.5-flash"]
    }
  },

  "routing": {
    "rules": [
      { "match": "^(gpt-|o[0-9]|chatgpt)", "provider": "openai" },
      { "match": "^claude", "provider": "anthropic" },
      { "match": "^glm", "provider": "glm" }
    ]
  },

  "injection": {
    "enabled": false,
    "systemMode": "prepend",
    "system": "",
    "depth": []
  },

  "anthropic": {
    "promptCaching": true,
    "defaultMaxTokens": 4096
  },

  "cacheRefresh": {
    "enabled": true,
    "intervalMinutes": 4.5,
    "maxRefreshes": 3,
    "maxTokens": 1,
    "maxChats": 5
  }
}
